# Client + server (safe to expose to the browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server ONLY — never ship to the browser. Used exclusively by serviceCommand() (imports/webhooks/jobs).
SUPABASE_SERVICE_ROLE_KEY=

# Feature gate for the single-use invite exchange (/invite/[token]). Leave unset/0 until the
# session-mint step is wired and the DB is certified against Supabase-local; set to 1 to enable.
INVITE_EXCHANGE_ENABLED=
