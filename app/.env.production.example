# Production env for the Next app — set these as env vars on the Coolify service (NOT committed).
# All are read SERVER-SIDE only; none are exposed to the browser.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# NEVER ship the service-role key to the browser. Used only by serviceCommand() (invite exchange, imports).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Keep the invite exchange OFF until email OTP is verified end-to-end and the DB is certified on
# supabase-local (ADR-1). Set to 1 only when ready.
INVITE_EXCHANGE_ENABLED=0
